# Application
APP_PORT=8080
APP_ENV=development
APP_VERSION=1.0.0

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=onepiece
DB_PASSWORD=onepiece_secret
DB_NAME=onepiece_db
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Logging
LOG_LEVEL=debug

# Rate Limiting (requests per minute)
RATE_LIMIT_PUBLIC=10
RATE_LIMIT_AUTHENTICATED=60
